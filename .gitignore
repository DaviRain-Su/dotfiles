# ============================================
# macOS
# ============================================
.DS_Store
.AppleDouble
.LSOverride

# ============================================
# 备份文件
# ============================================
*.backup
*.bak
*~
*.swp
*.tmp

# ============================================
# 敏感配置 - 绝对不能提交到 Git！
# ============================================
# 本地环境变量（包含 API Keys、Token 等）
.extra
.env
.env.local
.env.*.local

# 本地覆盖配置
*.local
config.local.*
!config.local.example

# API Keys 和 Token 文件
*api-key*
*apikey*
*secret*
*token*
*password*
*credential*
*.pem
*.key

# ============================================
# 工具缓存
# ============================================
.cache/
node_modules/
vendor/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# ============================================
# IDE
# ============================================
.idea/
.vscode/
*.sublime-*

# ============================================
# 日志
# ============================================
*.log
logs/
