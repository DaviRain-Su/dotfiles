#!/bin/bash
# AI Agent 统一入口
# 使用: ai <agent> [args]
#       ai list          # 列出所有 agent
#       ai install       # 安装所有 agent

set -e

DOTFILES="${HOME}/dotfiles"
AGENTS_DIR="${DOTFILES}/configs/agents"

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_info() { echo -e "${BLUE}[ai]${NC} $1"; }
print_success() { echo -e "${GREEN}[ai]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[ai]${NC} $1"; }
print_error() { echo -e "${RED}[ai]${NC} $1"; }

# 检查 agent 是否安装
check_agent() {
    local agent=$1
    case $agent in
        claude)
            command -v claude &> /dev/null
            ;;
        codex)
            command -v codex &> /dev/null
            ;;
        opencode)
            command -v opencode &> /dev/null
            ;;
        pi)
            command -v pi &> /dev/null
            ;;
        hermes)
            command -v hermes &> /dev/null
            ;;
        factory|droid)
            command -v droid &> /dev/null
            ;;
        *)
            return 1
            ;;
    esac
}

# 获取 agent 版本
get_version() {
    local agent=$1
    case $agent in
        claude)
            claude --version 2>/dev/null | head -1 || echo "unknown"
            ;;
        codex)
            codex --version 2>/dev/null | head -1 || echo "unknown"
            ;;
        opencode)
            opencode --version 2>/dev/null | head -1 || echo "unknown"
            ;;
        pi)
            pi --version 2>/dev/null | head -1 || echo "unknown"
            ;;
        hermes)
            hermes --version 2>/dev/null | head -1 || echo "unknown"
            ;;
        factory|droid)
            droid --version 2>/dev/null | head -1 || echo "unknown"
            ;;
        *)
            echo "unknown"
            ;;
    esac
}

# 列出所有 agent
list_agents() {
    echo ""
    echo "🤖 已安装的 AI Agent:"
    echo ""
    
    local agents=("claude" "codex" "opencode" "pi" "hermes" "droid")
    
    for agent in "${agents[@]}"; do
        if check_agent "$agent"; then
            local version=$(get_version "$agent")
            printf "  ✅ %-10s %s\n" "$agent" "$version"
        else
            printf "  ❌ %-10s (未安装)\n" "$agent"
        fi
    done
    
    echo ""
    echo "使用: ai <agent> 启动对应的 agent"
    echo "      ai install  安装所有 agent"
    echo ""
}

# 安装所有 agent
install_agents() {
    print_info "开始安装 AI Agent..."
    
    # 检查 npm
    if ! command -v npm &> /dev/null; then
        print_error "npm 未安装，请先安装 Node.js"
        exit 1
    fi
    
    # 安装 Claude Code
    if ! check_agent "claude"; then
        print_info "安装 Claude Code..."
        npm install -g @anthropic-ai/claude-code
        print_success "Claude Code 安装完成"
    else
        print_warning "Claude Code 已安装，跳过"
    fi
    
    # 安装 Codex
    if ! check_agent "codex"; then
        print_info "安装 Codex..."
        npm install -g @openai/codex
        print_success "Codex 安装完成"
    else
        print_warning "Codex 已安装，跳过"
    fi
    
    # 安装 OpenCode
    if ! check_agent "opencode"; then
        print_info "安装 OpenCode..."
        if command -v bun &> /dev/null; then
            bun install -g @opengb/opencode
        else
            npm install -g @opengb/opencode
        fi
        print_success "OpenCode 安装完成"
    else
        print_warning "OpenCode 已安装，跳过"
    fi
    
    # 安装 Pi
    if ! check_agent "pi"; then
        print_info "安装 Pi..."
        npm install -g @mariozechner/pi-coding-agent
        print_success "Pi 安装完成"
    else
        print_warning "Pi 已安装，跳过"
    fi
    
    # 安装 Hermes
    if ! check_agent "hermes"; then
        print_info "安装 Hermes..."
        if command -v pip3 &> /dev/null; then
            pip3 install hermes-agent
        else
            print_error "pip3 未安装，无法安装 Hermes"
        fi
        print_success "Hermes 安装完成"
    else
        print_warning "Hermes 已安装，跳过"
    fi
    
    # 安装 Factory.ai (droid)
    if ! check_agent "droid"; then
        print_info "安装 Factory.ai CLI (droid)..."
        curl -fsSL https://app.factory.ai/cli | sh
        print_success "Factory.ai CLI (droid) 安装完成"
    else
        print_warning "Factory.ai (droid) 已安装，跳过"
    fi
    
    print_success "所有 AI Agent 安装完成！"
    list_agents
}

# 启动 agent
launch_agent() {
    local agent=$1
    shift  # 移除第一个参数，剩下的传给 agent
    
    if ! check_agent "$agent"; then
        print_error "$agent 未安装，运行 'ai install' 安装"
        exit 1
    fi
    
    # 加载 agent 特定的配置
    local config_file="${AGENTS_DIR}/${agent}/config.sh"
    if [ -f "$config_file" ]; then
        source "$config_file"
    fi
    
    # 启动 agent
    case $agent in
        claude)
            print_info "启动 Claude Code..."
            claude "$@"
            ;;
        codex)
            print_info "启动 Codex..."
            codex "$@"
            ;;
        opencode)
            print_info "启动 OpenCode..."
            opencode "$@"
            ;;
        pi)
            print_info "启动 Pi..."
            pi "$@"
            ;;
        hermes)
            print_info "启动 Hermes..."
            hermes "$@"
            ;;
        droid)
            print_info "启动 Factory.ai (droid)..."
            droid "$@"
            ;;
        *)
            print_error "未知的 agent: $agent"
            exit 1
            ;;
    esac
}

# 主入口
case "${1:-}" in
    list|ls|-l|--list)
        list_agents
        ;;
    install|-i|--install)
        install_agents
        ;;
    claude|codex|opencode|pi|hermes|droid)
        launch_agent "$@"
        ;;
    help|-h|--help)
        echo ""
        echo "🤖 AI Agent 统一入口"
        echo ""
        echo "用法:"
        echo "  ai list          列出所有已安装的 agent"
        echo "  ai install       安装所有 agent"
        echo "  ai claude        启动 Claude Code"
        echo "  ai codex         启动 Codex"
        echo "  ai opencode      启动 OpenCode"
        echo "  ai pi            启动 Pi"
        echo "  ai hermes        启动 Hermes"
        echo "  ai droid         启动 Factory.ai (droid)"
        echo ""
        echo "示例:"
        echo "  ai claude        启动 Claude Code"
        echo "  ai pi            启动 Pi"
        echo "  ai droid         启动 Factory.ai (droid)"
        echo ""
        ;;
    *)
        if [ -z "$1" ]; then
            list_agents
        else
            print_error "未知命令: $1"
            echo "运行 'ai help' 查看帮助"
            exit 1
        fi
        ;;
esac