#!/bin/bash
# AI 开发专用 tmux 会话管理

set -e

PROJECT_NAME="${1:-$(basename $(pwd))}"
SESSION_NAME="${PROJECT_NAME//./-}"  # 替换点为横线

# 颜色
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_info() { echo -e "${BLUE}[tmux-ai]${NC} $1"; }
print_success() { echo -e "${GREEN}[tmux-ai]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[tmux-ai]${NC} $1"; }

# 检查 tmux 是否安装
if ! command -v tmux &> /dev/null; then
    print_warning "tmux 未安装，正在安装..."
    brew install tmux
fi

# 检查会话是否存在
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    print_info "会话 '$SESSION_NAME' 已存在，正在 attach..."
    print_info "可以在 PyCharm/其他终端运行: tmux attach -t $SESSION_NAME"
    tmux attach-session -t "$SESSION_NAME"
else
    print_info "创建新会话: $SESSION_NAME"
    print_info "项目目录: $(pwd)"
    
    # 创建新会话，进入项目目录，启动 pi
    tmux new-session -d -s "$SESSION_NAME" -c "$(pwd)"
    
    # 可选：自动启动 pi（取消注释启用）
    # tmux send-keys -t "$SESSION_NAME" "pi" C-m
    
    print_success "会话已创建！"
    echo ""
    echo "用法:"
    echo "  1. 当前终端: tmux attach -t $SESSION_NAME"
    echo "  2. PyCharm: tmux attach -t $SESSION_NAME"
    echo "  3. Ghostty: tmux attach -t $SESSION_NAME"
    echo ""
    echo "快捷键:"
    echo "  Ctrl+a c    新建窗口"
    echo "  Ctrl+a |    垂直分屏"
    echo "  Ctrl+a -    水平分屏"
    echo "  Ctrl+a h/j/k/l  导航"
    echo "  Ctrl+a d    detach（后台运行）"
    echo ""
    
    # 自动 attach
    tmux attach-session -t "$SESSION_NAME"
fi
