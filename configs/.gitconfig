# Git 配置
# 注意：使用前请修改用户名和邮箱

[core]
    pager = delta
    editor = nvim

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    light = false
    side-by-side = true

[init]
    defaultBranch = main

[push]
    default = simple

[pull]
    rebase = false

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph --all --decorate

# 请添加你的个人信息
# [user]
#     name = Your Name
#     email = your.email@example.com
